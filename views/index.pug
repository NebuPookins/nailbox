doctype html
html(lang="en")
	head
		meta(charset="utf-8")
		meta(http-equiv="X-UA-Compatible" content="IE=edge")
		meta(name="viewport" content="width=device-width, initial-scale=1")
		title Nailbox
		link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.6/css/bootstrap.min.css")
		link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.6/css/bootstrap-theme.min.css")
		link(rel="shortcut icon" type="image/png" href="/public/favicon.png")
		style(type="text/css").
				.spin {
				-webkit-animation:spin 4s linear infinite;
				-moz-animation:spin 4s linear infinite;
				animation:spin 4s linear infinite;
			}
			@-moz-keyframes spin { 100% { -moz-transform: rotate(360deg); } }
			@-webkit-keyframes spin { 100% { -webkit-transform: rotate(360deg); } }
			@keyframes spin { 100% { -webkit-transform: rotate(360deg); transform:rotate(360deg); } }
			#later-picker .row .button {
				display: block;
				width: 100%;
				text-align: center;
				height: 100px;
				background: #f9f9f9;
				background-image: none;
				color: #333;
				border: solid 1px #fff;
				padding: 10px;
				white-space: normal;
			}
			#later-picker .row .button:hover {
				background: #563d7c;
				color: #fff;
			}
			#later-picker .row .button .glyphicon {
				display: block;
				font-size: 48px;
			}
			#later-picker .row .button .later-label {
				display: block;
				font-size: 18px;
				line-height: 1.2;
				margin-top: 6px;
			}
			#label-picker-root .label-picker-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
			}
			#label-picker-root .label-picker-grid .btn {
				min-width: 120px;
			}
			#label-picker-root .label-picker-grid .btn.label-picker-dimmed {
				opacity: 0.3;
			}
			.noselect {
				-webkit-touch-callout: none; /* iOS Safari */
				-webkit-user-select: none;   /* Chrome/Safari/Opera */
				-khtml-user-select: none;    /* Konqueror */
				-moz-user-select: none;      /* Firefox */
				-ms-user-select: none;       /* IE/Edge */
				user-select: none;           /* non-prefixed version, currently not supported by any browser */
			}
			.group {
				font-size: 120%;
				border-bottom: solid 2px black;
			}
			.thread {
				border-bottom: solid 1px black;
			}
			.thread:hover, .thread.visibility-updated:hover, .thread.visibility-when-i-have-time:hover, .thread.visibility-stale:hover {
				background: #bbf;
			}
			.thread.visibility-updated {
				background: #ff8;
			}
			.thread.visibility-stale {
				background: #f88;
			}
			.thread.visibility-when-i-have-time {
				background: #8f8;
			}
			.message-body {
				overflow-x: auto;
				overflow-y: hidden;
			}
			@media (min-width: 1041px) {
				#thread-viewer .modal-dialog {
					width: 949px;
				}
			}
			.message-body pre {
				white-space: pre-wrap;
				font-size: 11px;
				/*background-color: #f5f5f5;*/
				/*border: solid 1px #ccc;*/
				/*font-family:  Menlo,Monaco,Consolas,"Courier New",monospace;*/
				/*padding: 9.5px;*/
				/*overflow-x: auto;*/
			}
			.rule-item {
				margin-bottom: 15px;
			}
			.condition-item {
				margin-bottom: 10px;
			}
			.condition-item .form-control {
				margin-bottom: 5px;
			}
			#settings-modal .modal-dialog {
				width: 90%;
				max-width: 1000px;
			}
			@media (max-width: 767px) {
				html, body {
					overflow-x: hidden;
				}
				/* Rebalance Bootstrap .row negative margins to match tighter container gutter */
				.container {
					padding-left: 10px;
					padding-right: 10px;
				}
				.row {
					margin-left: -10px;
					margin-right: -10px;
				}
				.row > [class*="col-"] {
					padding-left: 10px;
					padding-right: 10px;
				}
				/* Stack thread columns vertically so buttons have room */
				.thread .row > [class*="col-"] {
					width: 100%;
					float: none;
				}
				/* Prevent long unbreakable text from overflowing */
				.thread .senders,
				.thread .subject,
				.thread .snippet,
				.thread .receivers {
					overflow-wrap: break-word;
					word-break: break-word;
					max-width: 100%;
				}
				/* Larger tap targets for action buttons */
				.thread .btn,
				.thread a.btn {
					min-height: 40px;
					min-width: 40px;
					padding: 8px 10px;
					font-size: 14px;
					margin-right: 2px;
					margin-bottom: 4px;
				}
				.thread-list-header .btn {
					padding: 6px 10px;
					font-size: 13px;
				}
				#auth-shell-controls-root.pull-right {
					float: none !important;
					display: block;
					margin-bottom: 6px;
				}
				#settings-btn {
					width: 100%;
					margin-bottom: 6px;
					box-sizing: border-box;
				}
				.modal-dialog {
					margin: 8px;
					width: auto !important;
				}
				#thread-viewer .modal-dialog {
					margin: 0 !important;
				}
				.modal-footer .btn {
					min-height: 40px;
					min-width: 40px;
					padding: 8px 12px;
					font-size: 14px;
					margin-bottom: 4px;
				}
				/* Constrain HTML email content to fit the screen */
				.message-body img,
				.message-body table,
				.message-body td,
				.message-body div {
					max-width: 100% !important;
					min-width: 0 !important;
					box-sizing: border-box !important;
				}
				.message-body img {
					height: auto !important;
				}
				/* Belt-and-suspenders: kill any inline min-width on any element */
				.message-body [style*="min-width"] {
					min-width: 0 !important;
				}
				/* Some emails also use the HTML width attribute (e.g. width="600").
				   max-width:100% handles it, but force width:auto to be safe on tables. */
				.message-body table {
					word-break: break-word;
					width: auto !important;
					border-collapse: collapse !important;
					border-spacing: 0 !important;
				}
			}
	body
		.container
			#auth-shell-status-root
			#main-container
				#auth-shell-controls-root.pull-right
				button.btn.btn-default#settings-btn
					span.glyphicon.glyphicon-cog
					|  Email Grouping Settings
				#thread-list-root
			#thread-viewer.modal.fade(tabindex="-1" role="dialog")
				.modal-dialog.modal-lg(role="document")
					.modal-content
						#thread-viewer-root
		#later-picker.modal.fade(tabindex="-1" role="dialog")
			.modal-dialog
				.modal-content
					.modal-header
						h4.modal-title Subject Line Here
					.modal-body
						#later-picker-root
		#label-picker.modal.fade(tabindex="-1" role="dialog")
			.modal-dialog
				.modal-content
					.modal-header
						h4.modal-title Subject Line Here
					.modal-body
						#label-picker-root
		#settings-modal.modal.fade(tabindex="-1" role="dialog")
			.modal-dialog.modal-lg
				.modal-content
					.modal-header
						button.close(type="button" data-dismiss="modal" aria-label="Close")
							span(aria-hidden="true") &times;
						h4.modal-title Email Grouping Rules
					.modal-body
						#grouping-rules-root
					.modal-footer
						button.btn.btn-default(type="button" data-dismiss="modal") Cancel
		#grouping-rules-debug-modal.modal.fade(tabindex="-1" role="dialog")
			.modal-dialog.modal-lg
				.modal-content
					#grouping-rules-debug-root
		script(type='text/javascript' src='https://cdnjs.cloudflare.com/ajax/libs/lodash.js/4.2.1/lodash.js')
		script(type='text/javascript' src='https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.11.2/moment.js')
		script(type='text/javascript' src="public/filesize.min.js")
		script(type='text/javascript' src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2014-11-29/FileSaver.min.js")
		script(type='text/javascript' src=assetPath('main.ts'))
